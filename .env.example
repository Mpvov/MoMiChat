# Application
PROJECT_NAME="MoMiChat"
VERSION="0.1.0"
DEBUG=True

# API
APP_BASE_URL="https://your-ngrok-url.ngrok-free.app" # your domain
API_V1_PREFIX="/api/v1"
ALLOWED_ORIGINS=["*"]

# Database
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5433/momichat"
REDIS_URL="redis://localhost:6379/0"

# AI Models (Factory pattern allows switching)
DEFAULT_LLM_PROVIDER="openai" # 'openai' or 'gemini'
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AIza..."
HF_TOKEN="hf_..."

# PayOS Integration
PAYOS_CLIENT_ID="your-client-id"
PAYOS_API_KEY="your-api-key"
PAYOS_CHECKSUM_KEY="your-checksum-key"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-bot-token"
OWNER_CHAT_ID="your-telegram-chat-id" # For Mom's notifications

# Security
SECRET_KEY="your-secret-key-here"

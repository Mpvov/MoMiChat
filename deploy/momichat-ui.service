[Unit]
Description=MoMiChat Streamlit Dashboard
After=network.target momichat-api.service

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/MoMiChat
EnvironmentFile=/home/ubuntu/MoMiChat/.env
LimitNOFILE=65536
# Running on 127.0.0.1:8501 for secure SSH tunneling access
ExecStart=/home/ubuntu/.local/bin/uv run streamlit run src/momichat/ui/app.py --server.address 127.0.0.1 --server.port 8501
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
